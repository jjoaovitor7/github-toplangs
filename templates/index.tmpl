<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      GitHub Top Langs
    </title>

    <link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    />
    <link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
    />

    <style>
      body {
        font-family: "Poppins", sans-serif;
        opacity: 0;
        transition: opacity 1s ease-in-out;
      }
      body.visible {
        opacity: 1;
      }

      .card {
        max-width: 800px;
        opacity: 0;
        transform: translateY(32px);
        transition: opacity 2s ease, transform 2s ease;
      }
      .card.visible {
        opacity: 1;
        transform: translateY(0);
      }

      .github-corner {
        position: absolute;
        top: 16px;
        right: 16px;
        font-size: 2rem;
        transition: transform 0.2s;
      }
      .github-corner:hover {
        transform: scale(1.32);
      }

      .form-control::placeholder {
        color: var(--bs-secondary);
      }
      .form-control:-moz-placeholder {
        color: var(--bs-secondary);
      }
      .form-control::-webkit-input-placeholder {
        color: var(--bs-secondary);
      }

      #preview {
        max-height: 256px;
        transition: opacity 0.8s ease-in-out;
        opacity: 0;
      }
      #preview.visible {
        opacity: 1;
      }
    </style>
  </head>
  <body class="d-flex justify-content-center min-vh-100 position-relative bg-dark p-5">
    <a href="https://github.com/jjoaovitor7/github-toplangs"
      target="_blank" class="github-corner text-light">
      <i class="bi bi-github"></i>
    </a>

    <div class="card bg-dark text-light shadow p-5 rounded-4 w-100">
      <h2 class="mb-2 text-light">
        GitHub Top Langs
      </h2>

      <div class="mt-2 mb-4">
        <label for="user" class="form-label text-light">
          GitHub Username
        </label>
        <input
          id="user"
          class="form-control bg-dark text-light border-secondary"
          placeholder="username"
        />
      </div>

      <div class="mb-4">
        <label for="limit" class="form-label text-light">
          Limit
        </label>
        <input id="limit"
          class="form-control bg-dark text-light border-secondary"
          placeholder="8"
        />
      </div>

      <div class="mb-4">
        <label for="hide" class="form-label text-light">
          Hide (comma separated)
        </label>
        <input id="hide"
          class="form-control bg-dark text-light border-secondary"
          placeholder="mdx,ejs,python"
        />
      </div>

      <div class="d-flex gap-2 mb-4">
        <button id="generateBtn" class="btn btn-dark btn-sm border">
          Generate
        </button>
      </div>

      <div class="mt-4">
        <h4>
          Preview
        </h4>
        <img id="preview" class="img-fluid mb-4" />

        <h4>
          Markdown
        </h4>
        <textarea id="markdown"
          class="form-control bg-dark text-light border-secondary"
          readonly
          rows="2">
        </textarea>
      </div>
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        document.body.classList.add("visible");
        document.querySelector(".card").classList.add("visible");
      });

      const inputs = [
       document.getElementById("user"),
       document.getElementById("limit"),
       document.getElementById("hide")
      ];

      const previewImg = document.getElementById("preview");
      const md = document.getElementById("markdown");
      const generateBtn = document.getElementById("generateBtn");

      generateBtn.addEventListener("click", function(e) {
        generateBtn.disabled = true;
        const originalText = generateBtn.textContent;
        generateBtn.textContent = "Loading...";
        previewImg.classList.remove("visible");

        let url = `${document.location}toplangs?user=${encodeURIComponent(inputs[0].value)}`;

        if (inputs[1].value) {
          url += "&limit=" + encodeURIComponent(inputs[1].value);
        }

        if (inputs[2].value) {
          url += "&hide=" + encodeURIComponent(inputs[2].value);
        }

        const img = new Image();
        img.crossOrigin = "anonymous";
        img.src = url + "&t=" + Date.now();
        img.onload = function(e) {
          previewImg.src = img.src;
          previewImg.classList.add("visible");
          generateBtn.disabled = false;
          generateBtn.textContent = originalText;
        }

        md.value = `![GitHub Top Langs](${url})`;
      });
    </script>
  </body>
</html>

