<svg xmlns="http://www.w3.org/2000/svg" encoding="UTF-8"
  width="{{.Width}}"
  height="{{.Height}}"
  viewBox="0 0 {{.Width}} {{.Height}}"
  fill="none">
  <defs>
    <linearGradient id="shimmer">
      <stop offset="0%" stop-color="#ffffff" stop-opacity="0"/>
      <stop offset="50%" stop-color="#ffffff" stop-opacity="0.25"/>
      <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>
    </linearGradient>

    <animateTransform
      href="#shimmer"
      attributeName="gradientTransform"
      type="translate"
      from="-{{.Width}} 0"
      to="{{.Width}} 0"
      dur="2s"
      repeatCount="indefinite"
    />
  </defs>

  <style>
    <![CDATA[
      .title {
        font: 600 18px "Helvetica", sans-serif;
        fill: #fff;
      }

      .lang {
        font: 400 14px "Helvetica", sans-serif;
        fill: #c9d1d9;
      }

      .percent {
        font: 400 14px "Helvetica", sans-serif;
        fill: #8b949e;
      }
    ]]>
  </style>

  <rect
    x="0"
    y="0"
    width="100%"
    height="100%"
    rx="16"
    fill="#0d1117"
    stroke="#30363d"
  />

  <text x="16" y="64" class="title">
    Most Used Languages
  </text>

  {{range .Langs}}
    <text x="{{.ColX}}" y="{{.NameY}}" class="lang">
      {{.Name}}
    </text>

    <text x="{{.PercentX}}" y="{{.NameY}}" text-anchor="end" class="percent">
      {{printf "%.1f" .Percent}}%
    </text>

    <rect
      x="{{.ColX}}"
      y="{{.BarY}}"
      width="128"
      height="8"
      rx="4"
      fill="#21262d"
    />

    <rect
      x="{{.ColX}}"
      y="{{.BarY}}"
      width="{{printf "%.0f" .Width}}"
      height="8"
      rx="4"
      fill="{{.Color}}"
    />

    <rect
      x="{{.ColX}}"
      y="{{.BarY}}"
      width="{{printf "%.0f" .Width}}"
      height="8"
      rx="4"
      fill="url(#shimmer)"
    />
  {{end}}
</svg>
