<!-- <?xml version="1.0" encoding="UTF-8"?> -->
<svg xmlns="http://www.w3.org/2000/svg"
  width="{{.Width}}"
  height="{{.Height}}"
  viewBox="0 0 {{.Width}} {{.Height}}"
  fill="none">

  <defs xmlns="http://www.w3.org/2000/svg">
    <linearGradient xmlns="http://www.w3.org/2000/svg" id="shimmer" gradientUnits="userSpaceOnUse" x1="-200" y1="0" x2="200" y2="0">
      <stop offset="0%" stop-color="#ffffff" stop-opacity="0"/>
      <stop offset="50%" stop-color="#ffffff" stop-opacity="0.32"/>
      <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>

      <animateTransform
        attributeName="gradientTransform"
        type="translate"
        repeatCount="indefinite"
        values="-400 0; 400 0"
        dur="4s"
      />
    </linearGradient>
  </defs>

  <style>
    <![CDATA[
      .title {
        font: 600 18px "Helvetica", sans-serif;
        fill: {{.TitleColor}};
      }

      .lang {
        font: 400 14px "Helvetica", sans-serif;
        fill: #c9d1d9;
      }

      .percent {
        font: 400 14px "Helvetica", sans-serif;
        fill: #8b949e;
      }
    ]]>
  </style>

  <rect
    x="0"
    y="0"
    width="100%"
    height="100%"
    rx="32"
    fill="{{.BgColor}}"
  />

  <text x="32" y="64" class="title">
    Most Used Languages
  </text>

  {{range .Langs}}
    <g>
      <text x="{{.ColX}}" y="{{.NameY}}" class="lang">
        {{.Name}}
      </text>

      <text x="{{.PercentX}}" y="{{.NameY}}" text-anchor="end" class="percent">
        {{printf "%.1f" .Percent}}%
      </text>

      <rect
        x="{{.ColX}}"
        y="{{.BarY}}"
        width="128"
        height="8"
        rx="4"
        fill="#21262d"
      />

      <rect
        x="{{.ColX}}"
        y="{{.BarY}}"
        width="{{printf "%.0f" .Width}}"
        height="8"
        rx="4"
        fill="{{.Color}}"
      />

      <rect
        x="{{.ColX}}"
        y="{{.BarY}}"
        width="{{printf "%.0f" .Width}}"
        height="8"
        rx="4"
        fill="url(#shimmer)"
      />
    </g>
  {{end}}
</svg>
